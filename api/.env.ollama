# ─────────────────────────────────────────────────────────────
# MemWire — Fully Local Mode (Ollama)
#
# Copy to api/.env to run everything locally without any
# external LLM provider or API key.
#
#   cp api/.env.ollama api/.env
#   ./memwire.sh start
#
# Models are pulled automatically on first start:
#   llama3.2          — LLM (~2 GB, runs on CPU)
#   nomic-embed-text  — Embedder (~274 MB)
#
# To use a different Ollama model, change LLM_MODEL below and
# set OLLAMA_LLM_MODEL in your shell before starting:
#   OLLAMA_LLM_MODEL=mistral ./memwire.sh start
# ─────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=info

# ─── LLM Provider ────────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_API_KEY=ollama
LLM_MODEL=llama3.2
LLM_BASE_URL=http://ollama:11434

# ─── Embedding ───────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ─── Database ────────────────────────────────────────────────
USE_BUNDLED_DB=true
DATABASE_URL=postgresql://memwire:memwire@db:5432/memwire

# ─── Security ────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change-me-to-a-strong-random-secret
MEMWIRE_BOOTSTRAP_KEY=memwire-bootstrap

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
