# ─────────────────────────────────────────────────────────────
# MemWire API — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info

# ─── LLM Provider ────────────────────────────────────────────
# Options: openai | azure_openai | anthropic | ollama | custom
LLM_PROVIDER=openai

LLM_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o-mini

# Azure OpenAI (only used when LLM_PROVIDER=azure_openai)
LLM_BASE_URL=
AZURE_API_VERSION=2024-02-15-preview

# Ollama (only used when LLM_PROVIDER=ollama)
# When running inside Docker (via memwire.sh), use the service name:
# LLM_BASE_URL=http://ollama:11434
# LLM_MODEL=llama3.2

# ─── Embedding ───────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Ollama embedding (only used when LLM_PROVIDER=ollama)
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768

# ─── Database ────────────────────────────────────────────────
# Set USE_BUNDLED_DB=true to use the included Postgres container.
# Set to false and provide DATABASE_URL to use your own Postgres.
USE_BUNDLED_DB=true
DATABASE_URL=postgresql://memwire:memwire@db:5432/memwire

# ─── Security ────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change-me-to-a-strong-random-secret

# Bootstrap key — use this in the dashboard Settings page on first run.
# Create a real API key via the dashboard, then remove or rotate this.
MEMWIRE_BOOTSTRAP_KEY=memwire-bootstrap

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Memory Defaults ─────────────────────────────────────────
# Default number of conversation turns to include in context snapshots
DEFAULT_HISTORY_TURNS=20
# Maximum estimated tokens to include in a context snapshot
DEFAULT_MAX_CONTEXT_TOKENS=2000
# How many days to retain conversation memory before auto-deletion (0 = forever)
DATA_RETENTION_DAYS=90

# ─── Knowledge Base ──────────────────────────────────────────
# Max number of knowledge base caches held in memory (LRU)
MAX_KNOWLEDGE_BASES=20
# Default chunk size for document ingestion (characters)
KB_CHUNK_SIZE=1000
