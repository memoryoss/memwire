# ── Auth ──────────────────────────────────────────────────────
# Comma-separated list of API keys. Required for any production deploy;
# leave blank to disable auth (dev only).
MEMWIRE_API_KEYS=

# ── Tenancy ──────────────────────────────────────────────────
MEMWIRE_ORG_ID=default
MEMWIRE_COLLECTION_PREFIX=mw_

# ── Embedding provider ───────────────────────────────────────
# Default is local FastEmbed (sentence-transformers/all-MiniLM-L6-v2, 384-dim).
# To use an OpenAI-compatible endpoint (Ollama, OpenAI, Together, etc.):
EMBEDDING_PROVIDER=fastembed
# EMBEDDING_PROVIDER=openai-compatible
# EMBEDDING_API_URL=http://host.docker.internal:11434/v1
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIM=768

# ── LLM provider (powers Studio playground via POST /v1/chat) ─
# Memwire's chat endpoint proxies to any OpenAI-compatible
# /v1/chat/completions endpoint. Leave OPENAI_API_KEY empty to disable
# /v1/chat (recall/search/etc still work).
OPENAI_API_KEY=
# Default upstream is OpenAI. Override for Anthropic-compat / Together /
# Groq / Ollama / vLLM / LiteLLM:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1   # Ollama
OPENAI_DEFAULT_MODEL=gpt-4o-mini
# Models shown in Studio's playground dropdown:
OPENAI_AVAILABLE_MODELS=gpt-4o-mini,gpt-4o

# ── CORS (Studio) ────────────────────────────────────────────
# Comma-separated origins. Default "*" allows browser calls from anywhere.
# Restrict to your Studio host in production.
MEMWIRE_CORS_ORIGINS=*

# ── Qdrant override (only if running Qdrant outside docker-compose) ──
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
