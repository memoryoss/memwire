# OpenAI — required for chat apps
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Qdrant — set automatically by docker-compose, override only if using external Qdrant
# QDRANT_URL=http://qdrant:6333

# MemWire metadata DB — defaults to sqlite:///memwire_{user_id}.db
# MEMWIRE_DB_URL=sqlite:////data/memwire.db
