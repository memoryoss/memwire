{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MemWire",
  "openapi": "api-reference/openapi.json",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "logo": {
    "light": "/logo/logo-dark.png",
    "dark": "/logo/logo-light.png",
    "width": 100
  },
  "favicon": "/favicon.svg",
  "metadata": {
    "og:title": "MemWire — Self-hosted AI Memory Infrastructure",
    "og:description": "Open source, graph-powered AI memory layer. Deploy on-premise with your own LLM and vector database. Zero vendor lock-in.",
    "og:image": "/images/og-image.png",
    "twitter:title": "MemWire — Self-hosted AI Memory Infrastructure",
    "twitter:description": "Open source, graph-powered AI memory layer. Deploy on-premise with your own LLM and vector database. Zero vendor lock-in.",
    "twitter:image": "/images/og-image.png",
    "twitter:card": "summary_large_image"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Open Source",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/overview",
              "features/graph-memory",
              "features/multi-tenancy",
              "features/knowledge-base",
              "features/hybrid-search",
              "features/reranker",
              "features/llm-free-classification",
              "features/adaptive-feedback"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration",
              {
                "group": "Vector Databases",
                "icon": "hard-drive",
                "pages": [
                  "vector-databases",
                  "vector-databases/qdrant"
                ]
              },
              {
                "group": "Embedding Models",
                "icon": "cube",
                "pages": [
                  "embedders",
                  "embedders/fastembed"
                ]
              },
              {
                "group": "LLMs",
                "icon": "message-bot",
                "pages": [
                  "llms",
                  "llms/openai",
                  "llms/azure-openai"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Memory",
            "pages": [
              "api-reference/endpoint/store",
              "api-reference/endpoint/recall",
              "api-reference/endpoint/search"
            ]
          },
          {
            "group": "System",
            "pages": [
              "api-reference/endpoint/health"
            ]
          }
        ]
      }
