          "icon": "github"
        },
        {
          "anchor": "Roadmap",
          "href": "https://github.com/memoryoss/memwire/blob/main/ROADMAP.md",
          "icon": "map"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/memoryoss/memwire"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://github.com/memoryoss/memwire"
    }
